# La Salumeria Silvio - Environment Configuration
# Copiar a .env y configurar los valores

# ==========================================
# Owner & Staff Authentication (AR-003)
# ==========================================

# Owner credentials - email y contraseña (o hash bcrypt)
OWNER_EMAIL=owner@lasalumeria.com
OWNER_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Staff emails - múltiples emails separados por coma
STAFF_EMAILS=staff1@lasalumeria.com,staff2@lasalumeria.com

# Staff password hashes - corresponder a cada email en STAFF_EMAILS (mismo orden, separado por coma)
STAFF_PASSWORD_HASHES=$2b$10$yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy,$2b$10$zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz