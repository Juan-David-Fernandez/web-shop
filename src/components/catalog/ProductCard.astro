---
/**
 * ProductCard - Individual product card component with placeholder handling
 */

import type { Product } from '../../types/catalog'

interface Props {
  product: Product
  class?: string
}

const { product, class: className } = Astro.props

const categoryLabels: Record<string, string> = {
  gastronomia: 'Gastronomia',
  salumeria: 'Salumeria',
  rosticceria: 'Rosticceria'
}

const categoryColors: Record<string, string> = {
  gastronomia: '#22C55E',
  salumeria: '#EF4444',
  rosticceria: '#F59E0B'
}

const categoryColor = categoryColors[product.category] || '#737373'
const categoryLabel = categoryLabels[product.category] || product.category

// Format price
const formattedPrice = product.price 
  ? new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(product.price)
  : null
---

<a href={`/catalog/${product.slug}`} class={`product-card ${className || ''}`} data-slug={product.slug}>
  <div class="card-image">
    <div class="placeholder-container">
      <svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" class="image-placeholder">
        <rect width="100%" height="100%" fill="#f5f5dc" />
        <rect x="0" y="0" width="100%" height="100%" fill="none" stroke="#d4c4a8" stroke-width="2" stroke-dasharray="8,4" />
        <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#8b7355" font-size="24" font-family="Georgia, serif">
          {product.name}
        </text>
      </svg>
    </div>
    <span class="category-badge" style={`background-color: ${categoryColor}`}>
      {categoryLabel}
    </span>
  </div>
  
  <div class="card-content">
    <h3 class="product-name">{product.name}</h3>
    <p class="product-description">{product.description}</p>
    {formattedPrice && <span class="product-price">{formattedPrice}</span>}
    
    {product.attributes && product.attributes.length > 0 && (
      <div class="product-attributes">
        {product.attributes.slice(0, 3).map(attr => (
          <span class="attribute-tag">{attr}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-gray-100);
    overflow: hidden;
  }

  .placeholder-container {
    width: 100%;
    height: 100%;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
  }

  .category-badge {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-family: var(--font-secondary);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-content {
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-name {
    font-family: var(--font-primary);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-xs) 0;
    line-height: 1.3;
  }

  .product-description {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin: 0 0 var(--spacing-sm) 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-price {
    font-family: var(--font-primary);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-brown);
    margin-top: auto;
  }

  .product-attributes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-sm);
  }

  .attribute-tag {
    padding: var(--spacing-xs) var(--spacing-sm);
    background: var(--color-gray-100);
    border-radius: var(--radius-sm);
    font-family: var(--font-secondary);
    font-size: var(--text-xs);
    color: var(--color-gray-600);
  }
</style>
