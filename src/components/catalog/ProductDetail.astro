---
/**
 * ProductDetail - Full product information display with gallery and related products
 */

import type { Product } from '../../types/catalog'
import Breadcrumb from '../shared/Breadcrumb.astro'

interface Props {
  product: Product
  relatedProducts?: Product[]
}

const { product, relatedProducts = [] } = Astro.props

const categoryLabels: Record<string, string> = {
  gastronomia: 'Gastronomia',
  salumeria: 'Salumeria',
  rosticceria: 'Rosticceria'
}

const categoryColors: Record<string, string> = {
  gastronomia: '#22C55E',
  salumeria: '#EF4444',
  rosticceria: '#F59E0B'
}

const categoryColor = categoryColors[product.category] || '#737373'
const categoryLabel = categoryLabels[product.category] || product.category

// Format price
const formattedPrice = product.price 
  ? new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(product.price)
  : null

// Breadcrumb items
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Catalogo', href: '/catalog' },
  { label: categoryLabel, href: `/catalog?category=${product.category}` },
  { label: product.name, href: '' }
]
---

<article class="product-detail">
  <Breadcrumb items={breadcrumbItems} />
  
  <div class="product-main">
    <div class="product-gallery">
      <div class="main-image">
        {product.image ? (
          <img src={product.image} alt={product.name} id="main-product-image" />
        ) : (
          <div class="placeholder-wrapper">
            <svg width="600" height="450" viewBox="0 0 600 450" xmlns="http://www.w3.org/2000/svg" class="image-placeholder">
              <rect width="100%" height="100%" fill="#f5f5dc" />
              <rect x="0" y="0" width="100%" height="100%" fill="none" stroke="#d4c4a8" stroke-width="2" stroke-dasharray="8,4" />
              <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#8b7355" font-size="32" font-family="Georgia, serif">
                {product.name}
              </text>
            </svg>
          </div>
        )}
      </div>
    </div>
    
    <div class="product-info">
      <span class="category-badge" style={`background-color: ${categoryColor}`}>
        {categoryLabel}
      </span>
      
      <h1 class="product-title">{product.name}</h1>
      <p class="product-description">{product.description}</p>
      
      {formattedPrice && (
        <div class="price-container">
          <span class="product-price">{formattedPrice}</span>
        </div>
      )}
      
      {product.attributes && product.attributes.length > 0 && (
        <div class="product-attributes">
          <h3 class="attributes-title">Caratteristiche:</h3>
          <div class="attributes-list">
            {product.attributes.map(attr => (
              <span class="attribute-tag">{attr}</span>
            ))}
          </div>
        </div>
      )}
      
      <div class="product-actions">
        <button class="add-to-cart-button" data-product-id={product.id}>
          Aggiungi al carrello
        </button>
      </div>
      
      <a href="/catalog" class="back-link">
        ← Torna al catalogo
      </a>
    </div>
  </div>
  
  {relatedProducts.length > 0 && (
    <section class="related-products">
      <h2 class="related-title">Potrebbe piacerti anche</h2>
      <div class="related-grid">
        {relatedProducts.slice(0, 3).map(related => (
          <a href={`/catalog/${related.slug}`} class="related-card">
            <div class="related-image">
              {related.image ? (
                <img src={related.image} alt={related.name} loading="lazy" />
              ) : (
                <div class="related-placeholder">
                  <span>{related.name}</span>
                </div>
              )}
            </div>
            <h3 class="related-name">{related.name}</h3>
            {related.price && (
              <span class="related-price">
                {new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(related.price)}
              </span>
            )}
          </a>
        ))}
      </div>
    </section>
  )}
</article>

<style>
  .product-detail {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-lg);
  }

  .product-main {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
  }

  @media (min-width: 768px) {
    .product-main {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .product-main {
      gap: var(--spacing-3xl);
    }
  }

  /* Gallery */
  .product-gallery {
    width: 100%;
  }

  .main-image {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-gray-100);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder-wrapper {
    width: 100%;
    height: 100%;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
  }

  /* Product Info */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .category-badge {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-sm);
    font-family: var(--font-secondary);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
  }

  .product-title {
    font-family: var(--font-primary);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0;
    line-height: 1.2;
  }

  .product-description {
    font-family: var(--font-secondary);
    font-size: var(--text-lg);
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0;
  }

  .price-container {
    padding: var(--spacing-md) 0;
    border-top: 1px solid var(--color-gray-200);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .product-price {
    font-family: var(--font-primary);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-brown);
  }

  .product-attributes {
    padding: var(--spacing-md) 0;
  }

  .attributes-title {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gray-700);
    margin: 0 0 var(--spacing-sm) 0;
  }

  .attributes-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .attribute-tag {
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--color-gray-100);
    border-radius: var(--radius-sm);
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    color: var(--color-gray-700);
  }

  .product-actions {
    padding: var(--spacing-lg) 0;
  }

  .add-to-cart-button {
    width: 100%;
    padding: var(--spacing-md) var(--spacing-xl);
    background: var(--color-brown);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-white);
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .add-to-cart-button:hover {
    background: var(--color-brown-dark);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-brown);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-brown-dark);
  }

  /* Related Products */
  .related-products {
    padding-top: var(--spacing-2xl);
    border-top: 1px solid var(--color-gray-200);
  }

  .related-title {
    font-family: var(--font-primary);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-xl) 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--spacing-lg);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .related-image {
    aspect-ratio: 4 / 3;
    background: var(--color-gray-100);
    overflow: hidden;
  }

  .related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream);
  }

  .related-placeholder span {
    font-family: var(--font-primary);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    text-align: center;
    padding: var(--spacing-sm);
  }

  .related-name {
    font-family: var(--font-primary);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: var(--spacing-md);
    padding-bottom: 0;
  }

  .related-price {
    font-family: var(--font-primary);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-brown);
    margin: 0 var(--spacing-md) var(--spacing-md);
  }
</style>
