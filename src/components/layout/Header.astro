---
/**
 * Header component - Main navigation header
 */
---

<header class="header">
  <div class="container">
    <div class="header-content">
      <a href="/" class="logo">
        <span class="logo-text">La Salumeria Silvio</span>
      </a>
      
      <nav class="nav-main" aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/catalog" class="nav-link">Catalogo</a></li>
          <li><a href="/storia" class="nav-link">La Nostra Storia</a></li>
        </ul>
      </nav>

      <div class="header-actions">
        <a href="/cart" class="cart-link" aria-label="Shopping cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="cart-count" id="cart-count" style="display: none;">0</span>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-cream);
    border-bottom: 2px solid var(--color-brown-light);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) 0;
    gap: var(--spacing-lg);
  }

  .logo {
    text-decoration: none;
    color: var(--color-brown);
  }

  .logo-text {
    font-family: var(--font-primary);
    font-size: var(--text-xl);
    font-weight: bold;
    letter-spacing: 0.5px;
  }

  .nav-main {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-main {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--spacing-xl);
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-brown);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    font-weight: 500;
    padding: var(--spacing-xs) var(--spacing-sm);
    transition: color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-brown-dark);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .cart-link {
    color: var(--color-brown);
    transition: color var(--transition-fast);
  }

  .cart-link:hover {
    color: var(--color-brown-dark);
  }

  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: var(--color-gold);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: bold;
    padding: 2px 6px;
    border-radius: var(--radius-full);
    min-width: 18px;
    text-align: center;
  }

  .container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }
</style>
