---
/**
 * Header component - Main navigation header
 */
---

<header class="header">
  <div class="container">
    <div class="header-content">
      <a href="/" class="logo">
        <span class="logo-text">La Salumeria Silvio</span>
      </a>
      
      <nav class="nav-main" aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/catalog" class="nav-link">Catalogo</a></li>
          <li><a href="/storia" class="nav-link">La Nostra Storia</a></li>
        </ul>
      </nav>

      <div class="header-actions">
        <!-- Login/Profile button (shows based on auth state) -->
        <div id="auth-section">
          <a href="/account/login" class="login-btn" id="login-link" style="display: none;">Accedi</a>
          <div class="user-menu" id="user-menu" style="display: none;">
            <button class="user-btn" id="user-btn">
              <span class="user-avatar" id="user-avatar">U</span>
              <span class="user-name" id="user-name">Utente</span>
            </button>
            <div class="user-dropdown" id="user-dropdown">
              <a href="/account/profile" class="dropdown-item">Profilo</a>
              <a href="/account/orders" class="dropdown-item">Ordini</a>
              <form method="POST" action="/api/auth/logout" class="logout-form">
                <button type="submit" class="dropdown-item logout-item">Esci</button>
              </form>
            </div>
          </div>
        </div>
        
        <a href="/cart" class="cart-link" aria-label="Shopping cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="cart-count" id="cart-count" style="display: none;">0</span>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-cream);
    border-bottom: 2px solid var(--color-brown-light);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) 0;
    gap: var(--spacing-lg);
  }

  .logo {
    text-decoration: none;
    color: var(--color-brown);
  }

  .logo-text {
    font-family: var(--font-primary);
    font-size: var(--text-xl);
    font-weight: bold;
    letter-spacing: 0.5px;
  }

  .nav-main {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-main {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--spacing-xl);
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-brown);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    font-weight: 500;
    padding: var(--spacing-xs) var(--spacing-sm);
    transition: color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-brown-dark);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .cart-link {
    color: var(--color-brown);
    transition: color var(--transition-fast);
  }

  .cart-link:hover {
    color: var(--color-brown-dark);
  }

  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: var(--color-gold);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: bold;
    padding: 2px 6px;
    border-radius: var(--radius-full);
    min-width: 18px;
    text-align: center;
  }

  /* Auth Section */
  .login-btn {
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-brown);
    color: var(--color-white);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-weight: 500;
    transition: background var(--transition-fast);
  }

  .login-btn:hover {
    background: var(--color-brown-dark);
  }

  .user-menu {
    position: relative;
  }

  .user-btn {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-sm);
    background: transparent;
    border: 1px solid var(--color-brown-light);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: var(--font-secondary);
  }

  .user-btn:hover {
    background: var(--color-cream);
  }

  .user-avatar {
    width: 24px;
    height: 24px;
    background: var(--color-brown);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: bold;
  }

  .user-name {
    color: var(--color-brown);
    font-weight: 500;
  }

  .user-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: var(--spacing-xs);
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    min-width: 150px;
    display: none;
    z-index: 100;
  }

  .user-dropdown.show {
    display: block;
  }

  .dropdown-item {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--color-gray-700);
    text-decoration: none;
    text-align: left;
    background: none;
    border: none;
    width: 100%;
    cursor: pointer;
    font-family: var(--font-secondary);
  }

  .dropdown-item:hover {
    background: var(--color-cream);
  }

  .logout-item {
    color: var(--color-error);
  }

  /* Session indicator badge */
  .session-badge {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    margin-left: 4px;
  }

  .container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }
</style>

<script>
  import { authStore, logout, getAuth } from '../../stores/authStore'

  // Get DOM elements
  const loginLink = document.getElementById('login-link')
  const userMenu = document.getElementById('user-menu')
  const userBtn = document.getElementById('user-btn')
  const userDropdown = document.getElementById('user-dropdown')
  const userAvatar = document.getElementById('user-avatar')
  const userName = document.getElementById('user-name')
  const logoutForm = document.querySelector('.logout-form') as HTMLFormElement

  // Check localStorage for auth
  function checkLocalAuth() {
    const stored = localStorage.getItem('auth_user')
    if (stored) {
      try {
        return JSON.parse(stored)
      } catch {
        return null
      }
    }
    return null
  }

  // Update UI based on auth state
  function updateAuthUI() {
    const auth = checkLocalAuth()
    console.log('Auth from localStorage:', auth)
    
    if (auth && auth.email) {
      // Show user menu
      if (loginLink) loginLink.style.display = 'none'
      if (userMenu) userMenu.style.display = 'block'
      
      // Update user info
      const initial = auth.nombre?.charAt(0).toUpperCase() || auth.email.charAt(0).toUpperCase()
      if (userAvatar) userAvatar.textContent = initial
      if (userName) userName.textContent = auth.nombre || auth.email.split('@')[0]
      
      console.log('Showing user menu, name:', auth.nombre)
    } else {
      // Show login button
      if (loginLink) loginLink.style.display = 'block'
      if (userMenu) userMenu.style.display = 'none'
      console.log('Showing login button')
    }
  }

  // Toggle dropdown
  userBtn?.addEventListener('click', (e) => {
    e.stopPropagation()
    userDropdown?.classList.toggle('show')
  })

  // Close dropdown when clicking outside
  document.addEventListener('click', () => {
    userDropdown?.classList.remove('show')
  })

  // Handle logout form
  logoutForm?.addEventListener('submit', async (e) => {
    e.preventDefault()
    console.log('Logging out...')
    
    try {
      await fetch('/api/auth/logout', {
        method: 'POST',
        credentials: 'same-origin'
      })
    } catch (err) {
      console.log('Logout API error (can be ignored):', err)
    }
    
    // Clear local storage
    localStorage.removeItem('auth_user')
    console.log('Redirecting to home')
    window.location.href = '/'
  })

  // Initialize
  updateAuthUI()
</script>
