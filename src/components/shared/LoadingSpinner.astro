---
/**
 * LoadingSpinner - A reusable loading indicator component
 */
interface Props {
  size?: 'sm' | 'md' | 'lg'
  message?: string
}

const { size = 'md', message } = Astro.props

const sizeMap = {
  sm: '24px',
  md: '40px',
  lg: '64px'
}

const ringWidth = {
  sm: '2px',
  md: '3px',
  lg: '4px'
}
---

<div class="loading-spinner" role="status" aria-live="polite">
  <div 
    class="spinner" 
    style={`width: ${sizeMap[size]}; height: ${sizeMap[size]}; border-width: ${ringWidth[size]}`}
  ></div>
  {message && <span class="message">{message}</span>}
</div>

<style>
  .loading-spinner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .spinner {
    border: var(--spacing-xs) solid var(--color-cream);
    border-top-color: var(--color-brown);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  .message {
    color: var(--color-brown);
    font-size: 0.875rem;
    font-family: var(--font-secondary);
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
