---
/**
 * ImagePlaceholder - A reusable placeholder component for images
 * Displays a placeholder SVG when no image is available
 */
interface Props {
  width?: number
  height?: number
  alt?: string
  class?: string
}

const { width = 400, height = 300, alt = 'Immagine non disponibile', class: className = '' } = Astro.props
---

<svg
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  xmlns="http://www.w3.org/2000/svg"
  class={`image-placeholder ${className}`}
  role="img"
  aria-label={alt}
>
  <rect width="100%" height="100%" fill="#f5f5dc" />
  <rect x="0" y="0" width="100%" height="100%" fill="none" stroke="#d4c4a8" stroke-width="2" stroke-dasharray="8,4" />
  <text 
    x="50%" 
    y="50%" 
    dominant-baseline="middle" 
    text-anchor="middle" 
    fill="#8b7355" 
    font-size={`${Math.min(width, height) / 12}`}
    font-family="Georgia, serif"
  >
    {alt}
  </text>
</svg>

<style>
  .image-placeholder {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>
