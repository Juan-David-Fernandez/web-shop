---
/**
 * NewsletterForm - Email signup with double opt-in
 */

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div class={`newsletter-form-wrapper ${className || ''}`}>
  <form id="newsletter-form" class="newsletter-form" novalidate>
    <div class="form-header">
      <h3 class="form-title">Iscriviti alla newsletter</h3>
      <p class="form-description">Ricevi novità e offerte speciali direttamente nella tua email</p>
    </div>
    
    <div class="form-fields">
      <div class="input-group">
        <label for="newsletter-email" class="sr-only">Email</label>
        <input 
          type="email" 
          id="newsletter-email" 
          name="email"
          class="email-input" 
          placeholder="La tua email"
          required
          autocomplete="email"
          aria-describedby="email-error"
        />
        <button type="submit" class="submit-button">
          Iscriviti
        </button>
      </div>
      
      <p id="email-error" class="error-message" role="alert" style="display: none;"></p>
    </div>
    
    <div class="privacy-notice">
      <p>
        I tuoi dati saranno trattati secondo la nostra 
        <a href="/privacy" class="privacy-link">Privacy Policy</a>
      </p>
    </div>
  </form>
  
  <div id="newsletter-success" class="newsletter-success" style="display: none;">
    <div class="success-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
    </div>
    <h3 class="success-title">Iscrizione in corso</h3>
    <p class="success-message">Controlla la tua email per confermare l'iscrizione</p>
  </div>
  
  <div id="newsletter-error" class="newsletter-error" role="alert" style="display: none;">
    <p class="error-text"></p>
  </div>
</div>

<style>
  .newsletter-form-wrapper {
    width: 100%;
    max-width: 500px;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .form-header {
    text-align: center;
  }

  .form-title {
    font-family: var(--font-primary);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-xs) 0;
  }

  .form-description {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-600);
    margin: 0;
  }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  @media (min-width: 640px) {
    .input-group {
      flex-direction: row;
    }
  }

  .email-input {
    flex: 1;
    padding: var(--spacing-md);
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-900);
    background: var(--color-white);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .email-input:focus {
    outline: none;
    border-color: var(--color-brown);
    box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
  }

  .email-input::placeholder {
    color: var(--color-gray-400);
  }

  .email-input.error {
    border-color: var(--color-error);
  }

  .submit-button {
    padding: var(--spacing-md) var(--spacing-xl);
    background: var(--color-brown);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    cursor: pointer;
    transition: background var(--transition-fast);
    white-space: nowrap;
  }

  .submit-button:hover {
    background: var(--color-brown-dark);
  }

  .submit-button:disabled {
    background: var(--color-gray-400);
    cursor: not-allowed;
  }

  .error-message {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    color: var(--color-error);
    margin: 0;
  }

  .privacy-notice {
    text-align: center;
  }

  .privacy-notice p {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    margin: 0;
  }

  .privacy-link {
    color: var(--color-brown);
    text-decoration: underline;
  }

  .privacy-link:hover {
    color: var(--color-brown-dark);
  }

  /* Success state */
  .newsletter-success {
    text-align: center;
    padding: var(--spacing-xl);
    background: var(--color-gray-50);
    border-radius: var(--radius-lg);
  }

  .success-icon {
    color: var(--color-success);
    margin-bottom: var(--spacing-md);
  }

  .success-title {
    font-family: var(--font-primary);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-sm) 0;
  }

  .success-message {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-600);
    margin: 0;
  }

  /* Error state */
  .newsletter-error {
    padding: var(--spacing-md);
    background: rgba(239, 68, 68, 0.1);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-error);
  }

  .error-text {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-error);
    margin: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  import { subscribeLead } from '../../stores/leadsStore'

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form') as HTMLFormElement
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement
    const errorMessage = document.getElementById('email-error')
    const successDiv = document.getElementById('newsletter-success')
    const errorDiv = document.getElementById('newsletter-error')

    // Email validation
    function isValidEmail(email: string): boolean {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
      return emailRegex.test(email)
    }

    // Show error message
    function showError(message: string) {
      if (errorMessage) {
        errorMessage.textContent = message
        errorMessage.style.display = 'block'
      }
      emailInput?.classList.add('error')
    }

    // Clear error
    function clearError() {
      if (errorMessage) {
        errorMessage.textContent = ''
        errorMessage.style.display = 'none'
      }
      emailInput?.classList.remove('error')
    }

    // Show success
    function showSuccess() {
      if (form) form.style.display = 'none'
      if (successDiv) successDiv.style.display = 'block'
      if (errorDiv) errorDiv.style.display = 'none'
    }

    // Show form error
    function showFormError(message: string) {
      if (form) form.style.display = 'none'
      if (successDiv) successDiv.style.display = 'none'
      if (errorDiv) {
        const errorText = errorDiv.querySelector('.error-text')
        if (errorText) errorText.textContent = message
        errorDiv.style.display = 'block'
      }
    }

    // Handle form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      clearError()

      const email = emailInput?.value.trim()

      // Validate email
      if (!email) {
        showError('L\'email è obbligatoria')
        return
      }

      if (!isValidEmail(email)) {
        showError('Inserisci un indirizzo email valido')
        return
      }

      // Disable submit button
      const submitButton = form.querySelector('.submit-button') as HTMLButtonElement
      if (submitButton) {
        submitButton.disabled = true
        submitButton.textContent = 'Iscrizione...'
      }

      try {
        const result = await subscribeLead(email)

        if (result.success) {
          showSuccess()
        } else {
          showFormError(result.message)
        }
      } catch (error) {
        showFormError('Si è verificato un errore. Riprova più tardi.')
      } finally {
        if (submitButton) {
          submitButton.disabled = false
          submitButton.textContent = 'Iscriviti'
        }
      }
    })

    // Clear error on input
    emailInput?.addEventListener('input', clearError)
  })
</script>
