---
/**
 * Admin Login Page - Authentication for admin panel
 */
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Accedi - La Salumeria Silvio">
  <div class="login-page">
    <div class="login-container">
      <div class="login-header">
        <h1 class="login-title">Area Amministrativa</h1>
        <p class="login-subtitle">Accedi per gestire gli iscritti alla newsletter</p>
      </div>
      
      <form id="login-form" class="login-form" novalidate>
        <div class="form-field">
          <label for="admin-email" class="field-label">Email</label>
          <input 
            type="email" 
            id="admin-email" 
            name="email"
            class="field-input" 
            placeholder="email@esempio.com"
            required
            autocomplete="email"
          />
        </div>
        
        <div class="form-field">
          <label for="admin-password" class="field-label">Password</label>
          <input 
            type="password" 
            id="admin-password" 
            name="password"
            class="field-input" 
            placeholder="••••••••"
            required
            autocomplete="current-password"
          />
        </div>
        
        <div id="login-error" class="login-error" role="alert" style="display: none;">
          <p class="error-text"></p>
        </div>
        
        <button type="submit" class="login-button">
          Accedi
        </button>
      </form>
      
      <div class="login-footer">
        <a href="/" class="back-link">← Torna alla home</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .login-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2xl);
    background: var(--color-cream);
  }

  .login-container {
    width: 100%;
    max-width: 400px;
    padding: var(--spacing-2xl);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .login-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .login-title {
    font-family: var(--font-primary);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-xs) 0;
  }

  .login-subtitle {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-600);
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .field-label {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-gray-700);
  }

  .field-input {
    padding: var(--spacing-md);
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-900);
    background: var(--color-white);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .field-input:focus {
    outline: none;
    border-color: var(--color-brown);
    box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
  }

  .field-input::placeholder {
    color: var(--color-gray-400);
  }

  .login-error {
    padding: var(--spacing-md);
    background: rgba(239, 68, 68, 0.1);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-error);
  }

  .error-text {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-error);
    margin: 0;
  }

  .login-button {
    padding: var(--spacing-md) var(--spacing-xl);
    background: var(--color-brown);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    cursor: pointer;
    transition: background var(--transition-fast);
    margin-top: var(--spacing-sm);
  }

  .login-button:hover {
    background: var(--color-brown-dark);
  }

  .login-footer {
    margin-top: var(--spacing-xl);
    text-align: center;
  }

  .back-link {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-brown);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-brown-dark);
    text-decoration: underline;
  }
</style>

<script>
  import { login, persistAuth } from '../../stores/authStore'

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('login-form') as HTMLFormElement
    const emailInput = document.getElementById('admin-email') as HTMLInputElement
    const passwordInput = document.getElementById('admin-password') as HTMLInputElement
    const errorDiv = document.getElementById('login-error')

    // Check if already logged in
    if (localStorage.getItem('auth_user')) {
      window.location.href = '/account/admin'
      return
    }

    // Show error
    function showError(message: string) {
      if (errorDiv) {
        const errorText = errorDiv.querySelector('.error-text')
        if (errorText) errorText.textContent = message
        errorDiv.style.display = 'block'
      }
    }

    // Handle form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      
      if (errorDiv) errorDiv.style.display = 'none'

      const email = emailInput?.value.trim()
      const password = passwordInput?.value

      if (!email || !password) {
        showError('Inserisci email e password')
        return
      }

      const result = await login(email, password)

      if (result.success) {
        const user = JSON.parse(localStorage.getItem('auth_user') || '{}')
        if (user) persistAuth(user)
        window.location.href = '/account/admin'
      } else {
        showError(result.message)
      }
    })
  })
</script>
