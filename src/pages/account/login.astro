---
/**
 * Login Page - Authentication for Cliente, Owner and Staff
 * Spec: user-login
 */
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Accedi - La Salumeria Silvio">
  <div class="login-page">
    <div class="login-container">
      <div class="login-header">
        <h1 class="login-title">Accedi al tuo account</h1>
        <p class="login-subtitle">
          Ingresa le tue credenziali per continuare
        </p>
      </div>

      <form id="login-form" class="login-form" method="POST" novalidate>
        <div class="form-field">
          <label for="email" class="field-label">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="field-input"
            placeholder="email@esempio.com"
            required
            autocomplete="email"
          />
          <span class="field-error" id="email-error"></span>
        </div>

        <div class="form-field">
          <label for="password" class="field-label">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="field-input"
            placeholder="••••••••"
            required
            autocomplete="current-password"
          />
          <span class="field-error" id="password-error"></span>
        </div>

        <div id="login-error" class="login-error" role="alert" style="display: none;">
          <p class="error-text"></p>
        </div>

        <button type="submit" class="login-button">
          Accedi
        </button>
      </form>

      <div class="login-footer">
        <p>
          Non hai un account?
          <a href="/account/register" class="register-link">Registrati</a>
        </p>
        <a href="/" class="back-link">← Torna alla home</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .login-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2xl);
    background: var(--color-cream);
  }

  .login-container {
    width: 100%;
    max-width: 400px;
    padding: var(--spacing-2xl);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .login-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .login-title {
    font-family: var(--font-primary);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-xs) 0;
  }

  .login-subtitle {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-600);
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .field-label {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-gray-700);
  }

  .field-input {
    padding: var(--spacing-md);
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-900);
    background: var(--color-white);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .field-input:focus {
    outline: none;
    border-color: var(--color-brown);
    box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
  }

  .field-input::placeholder {
    color: var(--color-gray-400);
  }

  .field-input.error {
    border-color: var(--color-error);
  }

  .field-error {
    font-family: var(--font-secondary);
    font-size: var(--text-sm);
    color: var(--color-error);
    min-height: 1.4em;
  }

  .login-error {
    padding: var(--spacing-md);
    background: rgba(239, 68, 68, 0.1);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-error);
  }

  .error-text {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-error);
    margin: 0;
  }

  .login-button {
    padding: var(--spacing-md) var(--spacing-xl);
    background: var(--color-brown);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white);
    cursor: pointer;
    transition: background var(--transition-fast);
    margin-top: var(--spacing-sm);
  }

  .login-button:hover {
    background: var(--color-brown-dark);
  }

  .login-footer {
    margin-top: var(--spacing-xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .login-footer p {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-gray-600);
    margin: 0;
  }

  .register-link {
    color: var(--color-brown);
    text-decoration: none;
    font-weight: 500;
  }

  .register-link:hover {
    text-decoration: underline;
  }

  .back-link {
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    color: var(--color-brown);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-brown-dark);
    text-decoration: underline;
  }
</style>

<script>
  import { login } from '../../stores/authStore'

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('login-form') as HTMLFormElement
    const emailInput = document.getElementById('email') as HTMLInputElement
    const passwordInput = document.getElementById('password') as HTMLInputElement
    const errorDiv = document.getElementById('login-error')

    // Check if already logged in
    if (localStorage.getItem('auth_user')) {
      window.location.href = '/account/profile'
      return
    }

    // Show error
    function showError(message: string) {
      if (errorDiv) {
        const errorText = errorDiv.querySelector('.error-text')
        if (errorText) errorText.textContent = message
        errorDiv.style.display = 'block'
      }
    }

    // Hide error
    function hideError() {
      if (errorDiv) {
        errorDiv.style.display = 'none'
      }
    }

    // Handle form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      hideError()

      const email = emailInput?.value.trim()
      const password = passwordInput?.value

      if (!email) {
        showError('El email es requerido')
        emailInput?.focus()
        return
      }

      if (!password) {
        showError('La password es requerida')
        passwordInput?.focus()
        return
      }

      const result = await login(email, password)

      if (result.success) {
        // Redirect to /account/profile (AR-002, R-LOG-004)
        window.location.href = '/account/profile'
      } else {
        showError(result.message)
        // Clear password field (S-LOG-006)
        if (passwordInput) passwordInput.value = ''
      }
    })
  })
</script>