---
/**
 * Category Page - Products filtered by category
 */
import Layout from '../../layouts/Layout.astro'
import ProductGrid from '../../components/catalog/ProductGrid.astro'
import FilterPanel from '../../components/catalog/FilterPanel.astro'
import SearchInput from '../../components/catalog/SearchInput.astro'
import NewsletterForm from '../../components/newsletter/NewsletterForm.astro'

export function getStaticPaths() {
  return [
    { params: { category: 'gastronomia' } },
    { params: { category: 'salumeria' } },
    { params: { category: 'rosticceria' } }
  ]
}

const { category } = Astro.params

const categoryLabels: Record<string, string> = {
  gastronomia: 'Gastronomia',
  salumeria: 'Salumeria',
  rosticceria: 'Rosticceria'
}

const categoryDescriptions: Record<string, string> = {
  gastronomia: 'Formaggi, latticini e specialità casearie artigianali',
  salumeria: 'Salumi e affettati DOP e IGP di alta qualità',
  rosticceria: 'Arrosti e specialità cotte ogni giorno'
}

const title = category ? ` ${categoryLabels[category] || category} | La Salumeria Silvio` : 'Catalogo | La Salumeria Silvio'
const description = category ? categoryDescriptions[category] || `Prodotti ${category}` : 'Scopri le nostre specialità'
---

<Layout title={title} description={description}>
  <div class="catalog-page">
    <header class="catalog-header">
      <h1 class="catalog-title">{categoryLabels[category] || category}</h1>
      <p class="catalog-subtitle">{categoryDescriptions[category] || ''}</p>
    </header>
    
    <div class="catalog-controls">
      <SearchInput />
      <FilterPanel />
    </div>
    
    <ProductGrid />
    
    <section class="newsletter-section">
      <NewsletterForm />
    </section>
  </div>
</Layout>

<script define:vars={{ category }}>
  import { updateFilters } from '../../stores/catalogStore'
  
  // Set initial category filter on load
  if (category && category !== 'tutti') {
    updateFilters({ category })
  }
</script>

<style>
  .catalog-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-lg);
  }

  .catalog-header {
    text-align: center;
    padding: var(--spacing-2xl) 0;
  }

  .catalog-title {
    font-family: var(--font-primary);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-sm) 0;
  }

  .catalog-subtitle {
    font-family: var(--font-secondary);
    font-size: var(--text-lg);
    color: var(--color-gray-600);
    margin: 0;
  }

  .catalog-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .newsletter-section {
    margin-top: var(--spacing-3xl);
    padding-top: var(--spacing-2xl);
    border-top: 1px solid var(--color-gray-200);
  }

  @media (min-width: 768px) {
    .catalog-page {
      padding: var(--spacing-2xl);
    }

    .catalog-title {
      font-size: var(--text-5xl);
    }
  }
</style>