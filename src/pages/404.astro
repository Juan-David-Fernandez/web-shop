---
/**
 * 404 Page - Product not found error page
 */

import Layout from '../layouts/Layout.astro'
---

<Layout title="Prodotto non trovato - La Salumeria Silvio">
  <div class="error-container">
    <div class="error-content">
      <h1 class="error-title">Prodotto non trovato</h1>
      <p class="error-message">
        Ci dispiace, il prodotto che stai cercando non è più disponibile o non esiste.
      </p>
      <div class="error-actions">
        <a href="/catalog" class="cta-button primary">
          Torna al catalogo
        </a>
        <a href="/" class="cta-button secondary">
          Torna alla home
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .error-container {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2xl);
  }

  .error-content {
    text-align: center;
    max-width: 500px;
  }

  .error-title {
    font-family: var(--font-primary);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 var(--spacing-md) 0;
  }

  .error-message {
    font-family: var(--font-secondary);
    font-size: var(--text-lg);
    color: var(--color-gray-600);
    margin: 0 0 var(--spacing-2xl) 0;
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  @media (min-width: 640px) {
    .error-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .cta-button {
    display: inline-block;
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: var(--radius-md);
    font-family: var(--font-secondary);
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cta-button.primary {
    background: var(--color-brown);
    color: var(--color-white);
    border: 2px solid var(--color-brown);
  }

  .cta-button.primary:hover {
    background: var(--color-brown-dark);
    border-color: var(--color-brown-dark);
  }

  .cta-button.secondary {
    background: transparent;
    color: var(--color-brown);
    border: 2px solid var(--color-brown);
  }

  .cta-button.secondary:hover {
    background: var(--color-brown);
    color: var(--color-white);
  }
</style>
